@model List<Character>
@using Microsoft.AspNetCore.Mvc.Rendering

<h2>Lista postaci</h2>


<form method="get" class="mb-3">
    <div class="form-group">
        <label>Filtruj po gildii:</label>
        <select name="guildId" class="form-control">
            <option value="">-- wszystkie --</option>
            @foreach (var g in ViewBag.Guilds as SelectList)
            {
                <option value="@g.Value">@g.Text</option>
            }
        </select>
    </div>

    <div class="form-group mt-2">
        <label>Filtruj po klasie:</label>
        <input type="text" name="characterClass" class="form-control" placeholder="np. Warrior" />
    </div>

    <button type="submit" class="btn btn-primary mt-2">Filtruj</button>
</form>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Class</th>
            <th>Level</th>
            <th>Guild</th>
            
        </tr>
    </thead>
    <tbody>
        @foreach (var character in Model)
        {
            <tr>
                <td>@character.Name</td>
                <td>@character.Class</td>
                <td>@character.Level</td>
                <td>@character.Guild?.Name</td>
                
            </tr>
        }
    </tbody>
</table>